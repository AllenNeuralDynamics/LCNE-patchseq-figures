#!/usr/bin/env bash
set -euo pipefail

CODE_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
RESULTS_DIR="$(cd -- "$CODE_DIR/.." && pwd)/results"
RECOMPUTE_FEATURES="${1:-0}"

if [[ "$RECOMPUTE_FEATURES" != "0" && "$RECOMPUTE_FEATURES" != "1" ]]; then
    echo "Error: recompute features must be 0 or 1" >&2
    exit 2
fi

PYTHONPATH="$CODE_DIR${PYTHONPATH:+:$PYTHONPATH}" python -u -m lcne_patchseq_figures.cli \
    --input "$CODE_DIR/lcne_patchseq_figures/data/AIBS_spreadsheet_pub.csv" \
    --output-dir "$RESULTS_DIR" \
    --recompute-features "$RECOMPUTE_FEATURES"